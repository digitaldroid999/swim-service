# Copy to `.env` and fill in secrets. Loaded by dotenv in config.js.
# Do not commit `.env` with real credentials.

# ── TFMData (SWIM_*) ────────────────────────────────────────────────────────
# Omit SWIM_URL for legacy AMQP: SWIM_HOST + SWIM_PORT, SWIM_VPN as virtual host.
# With SWIM_URL set:
#   amqp:// or amqps://  → AMQP 1.0
#   tcps:// tcp:// ws:// wss:// → Solace SMF (solclientjs); SWIM_VPN required for SMF
SWIM_URL=
SWIM_HOST=scds.swim.faa.gov
SWIM_PORT=5671
SWIM_USERNAME=
SWIM_PASSWORD=
SWIM_QUEUE=
SWIM_VPN=TFMS

# Optional for SMF/TLS
# SWIM_CLIENT_NAME=ca-swim-tfmdata
# SWIM_RECONNECT_RETRIES=-1
# SWIM_SSL_TRUST_STORES=
# SWIM_SSL_VALIDATE_CERTIFICATE=true

# ── SFDPS (SWIM_SFDPS_*) ─────────────────────────────────────────────────────
SWIM_SFDPS_URL=
SWIM_SFDPS_HOST=ems2.swim.faa.gov
SWIM_SFDPS_PORT=5671
SWIM_SFDPS_USERNAME=
SWIM_SFDPS_PASSWORD=
SWIM_SFDPS_QUEUE=
SWIM_SFDPS_VPN=FDPS

# SWIM_SFDPS_CLIENT_NAME=ca-swim-sfdps
# SWIM_SFDPS_RECONNECT_RETRIES=-1
# SWIM_SFDPS_SSL_TRUST_STORES=
# SWIM_SFDPS_SSL_VALIDATE_CERTIFICATE=true

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=3000
API_SECRET=

# ── Web push (VAPID) ─────────────────────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@example.com

# ── Database ────────────────────────────────────────────────────────────────
# DB_PATH=./data/swim.db
# SWIM_LOG_PRE_SAVE=true   # once per TFM/SFDPS message: log first event + flight_watches (sample format)
# Also respected: SWIM_LOG_DB_ROWS — values: 1, true, yes, on (case-insensitive). Run from project root so .env loads.
# Logs appear only when the broker delivers a message (startup line confirms the flag is seen).
# SWIM_LOG_PRE_SAVE_FILE=log/swim-pre-save.log   # optional path (relative to cwd); directory created if missing
# SWIM_LOG_SMF_INBOUND=true   # log each SMF MESSAGE: type, body length, attachment meta (debug empty-body issues)


# ── Netlify (optional blob sync) ─────────────────────────────────────────────
# NETLIFY_TOKEN=
# NETLIFY_SITE_ID=
